generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  passwordHash     String
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  applications     JobApplication[]
  interviews       Interview[]
}

enum ApplicationStatus {
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model JobApplication {
  id             String            @id @default(cuid())
  company        String
  role           String
  status         ApplicationStatus @default(APPLIED)

  location       String?
  jobUrl         String?
  source         String?
  contactName    String?
  contactEmail   String?
  resumeVersion  String?
  jobDescription String?

  notes          String?
  appliedAt      DateTime?
  followUpDate   DateTime?
  lastActivityAt DateTime          @default(now())

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  interviews      Interview[]

  @@index([userId])
  @@index([status])
  @@index([followUpDate])
}

enum InterviewType {
  HR
  TECHNICAL
  BEHAVIORAL
  MANAGERIAL
  FINAL
  OTHER
}

enum InterviewResult {
  SCHEDULED
  COMPLETED
  PASSED
  REJECTED
  CANCELLED
}

model Interview {
  id            String          @id @default(cuid())

  title         String?
  type          InterviewType   @default(TECHNICAL)
  round         Int             @default(1)
  scheduledAt   DateTime
  result        InterviewResult @default(SCHEDULED)
  notes         String?
  nextRoundAt   DateTime?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  applicationId  String?
  application    JobApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([scheduledAt])
  @@index([result])
  @@index([applicationId])
}